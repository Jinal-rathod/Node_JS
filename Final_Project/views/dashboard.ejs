<%- include("navbar") %>

<div class="container mt-4">
    <h2>Admin Dashboard</h2>

    <table class="table">
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Action</th>
        </tr>

        <% users.forEach(user => { %>
            <tr>
                <td><%= user.username %></td>
                <td><%= user.email %></td>
                <td><%= user.role %></td>
                <td>
                    <% if (user.role !== "admin") { %>
                        <a href="/admin/make-admin/<%= user._id %>" class="btn btn-warning">Make Admin</a>
                    <% } %>
                </td>
            </tr>
        <% }) %>
    </table>
</div>
