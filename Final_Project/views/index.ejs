<%- include("header") %>
<%- include("navbar") %>

<div class="max-w-6xl mx-auto px-6 py-10">

  <h1 class="text-4xl font-bold mb-8 text-center">
    ✨ Latest Blog Posts
  </h1>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

    <% posts.forEach(post => { %>

      <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-5 shadow-lg hover:scale-105 transition">

        <h2 class="text-xl font-semibold mb-2">
          <%= post.title %>
        </h2>

        <p class="text-gray-300 mb-3">
          <%= post.content.substring(0, 100) %>...
        </p>

        <p class="text-sm text-gray-400 mb-3">
          By <%= post.author.username %>
        </p>

        <a href="/posts/<%= post._id %>" 
           class="inline-block px-4 py-2 bg-blue-500 hover:bg-blue-600 rounded-lg transition">
          Read More
        </a>

        <% if (user && (user._id == post.author._id || user.role === "admin")) { %>
          <form method="POST" action="/posts/<%= post._id %>?_method=DELETE">
            <button class="mt-3 px-3 py-1 bg-red-500 hover:bg-red-600 rounded">
              Delete
            </button>
          </form>
        <% } %>

      </div>

    <% }) %>

  </div>

</div>

</body>
</html>