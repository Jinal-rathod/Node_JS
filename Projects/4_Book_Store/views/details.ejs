<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Details</title>
</head>

<body>
    <h2>
        <%= book.title %>
    </h2>
    <img src="<%= book.image %>" width="200">
    <p><strong>Author:</strong>
        <%= book.author %>
    </p>
    <p><strong>Category:</strong>
        <%= book.category %>
    </p>
    <p><strong>Price:</strong> ₹ <%= book.price %>
    </p>
    <p>
        <%= book.description %>
    </p>

    <a href="/">Back</a>
</body>

</html>